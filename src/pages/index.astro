---
import Base from "../layouts/Base.astro";
import {
  getRegister,
  getDistrictCounts,
  getCombinedStats,
} from "../lib/data";
import { getCollection } from "astro:content";

const act16 = getRegister("act16");
const permits = getRegister("permits");
const stats = getCombinedStats();

const RECENT_POSTS_COUNT = 3;
const recentPosts = (await getCollection("blog"))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, RECENT_POSTS_COUNT);

const act16Districts = [...getDistrictCounts("act16").entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 6);

const permitsDistricts = [...getDistrictCounts("permits").entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 6);

const recentAct16 = act16.records.slice(0, 4);
const recentPermits = permits.records.slice(0, 4);

const updatedDate = new Date(stats.lastUpdated).toLocaleDateString("bg-BG", {
  day: "numeric",
  month: "long",
  year: "numeric",
  hour: "2-digit",
  minute: "2-digit",
});
---

<Base title="Акт 16 Тракер — Строителни удостоверения в София">
  <section class="hero">
    <h1>Акт 16 Тракер</h1>
    <p class="hero__subtitle">
      Публичен регистър на разрешенията за строеж и удостоверенията за въвеждане
      в експлоатация (Акт 16) в Столична община. Данните се обновяват автоматично от
      <a href="https://nag.sofia.bg" target="_blank" rel="noopener">НАГ</a>.
    </p>
    <p class="hero__updated">Последна актуализация: {updatedDate}</p>
  </section>

  <section class="stat-grid" style="margin-top: 2rem;">
    <div class="card stat-card">
      <div class="value">{stats.totalAct16}</div>
      <div class="label">Удостоверения (Акт 16)</div>
    </div>
    <div class="card stat-card">
      <div class="value">{stats.totalPermits}</div>
      <div class="label">Разрешения за строеж</div>
    </div>
    <div class="card stat-card">
      <div class="value">{stats.totalDistricts}</div>
      <div class="label">Района в София</div>
    </div>
    <div class="card stat-card">
      <div class="value">{act16Districts[0]?.[0] ?? "—"}</div>
      <div class="label">Най-активен район (Акт 16)</div>
    </div>
  </section>

  <!-- Act 16 Section -->
  <section class="section" style="margin-top: 2.5rem;">
    <div class="section-header">
      <h2>Акт 16 — по район</h2>
      <a href="/register/act16">Виж всички &rarr;</a>
    </div>
    <div class="district-grid">
      {act16Districts.map(([name, count]) => (
        <a href={`/register/act16?region=${encodeURIComponent(name)}`} class="district-chip">
          <span class="district-chip__name">{name}</span>
          <span class="district-chip__count">{count}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="section" style="margin-top: 1.5rem;">
    <div class="section-header">
      <h2>Последни Акт 16</h2>
      <a href="/register/act16">Виж всички &rarr;</a>
    </div>
    <div class="recent-grid">
      {recentAct16.map((r) => (
        <div class="card recent-card">
          <div class="recent-card__header">
            <span class="recent-card__number">№ {r.number}</span>
            <span class="recent-card__date">{r.date}</span>
          </div>
          <p class="recent-card__object">{r.object.slice(0, 140)}{r.object.length > 140 ? "..." : ""}</p>
          <div class="recent-card__footer">
            {r.region && <span class="badge badge--district">{r.region}</span>}
            {r.constructionOversight && (
              <span class="recent-card__meta">{r.constructionOversight}</span>
            )}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Permits Section -->
  <section class="section" style="margin-top: 2.5rem;">
    <div class="section-header">
      <h2>Разрешения за строеж — по район</h2>
      <a href="/register/permits">Виж всички &rarr;</a>
    </div>
    <div class="district-grid">
      {permitsDistricts.map(([name, count]) => (
        <a href={`/register/permits?region=${encodeURIComponent(name)}`} class="district-chip district-chip--accent">
          <span class="district-chip__name">{name}</span>
          <span class="district-chip__count">{count}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="section" style="margin-top: 1.5rem;">
    <div class="section-header">
      <h2>Последни разрешения за строеж</h2>
      <a href="/register/permits">Виж всички &rarr;</a>
    </div>
    <div class="recent-grid">
      {recentPermits.map((r) => (
        <div class="card recent-card">
          <div class="recent-card__header">
            <span class="recent-card__number">№ {r.number}</span>
            <span class="recent-card__date">{r.date}</span>
          </div>
          <p class="recent-card__object">{r.object.slice(0, 140)}{r.object.length > 140 ? "..." : ""}</p>
          <div class="recent-card__footer">
            {r.region && <span class="badge badge--district">{r.region}</span>}
            {r.employer && (
              <span class="recent-card__meta">{r.employer}</span>
            )}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Blog Section -->
  <section class="section" style="margin-top: 2.5rem;">
    <div class="section-header">
      <h2>От блога</h2>
      <a href="/blog">Всички статии &rarr;</a>
    </div>
    <div class="blog-grid">
      {recentPosts.map((post) => {
        const formattedDate = post.data.date.toLocaleDateString("bg-BG", {
          day: "numeric",
          month: "long",
          year: "numeric",
        });
        return (
          <a href={`/blog/${post.id}`} class="card blog-home-card">
            <time class="blog-home-card__date" datetime={post.data.date.toISOString()}>
              {formattedDate}
            </time>
            <h3 class="blog-home-card__title">{post.data.title}</h3>
            <p class="blog-home-card__desc">{post.data.description.slice(0, 120)}...</p>
          </a>
        );
      })}
    </div>
  </section>
</Base>

<style>
  .hero {
    text-align: center;
    padding: 1.5rem 0 1rem;
  }

  .hero h1 {
    font-size: 1.85rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-coral) 50%, var(--color-accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1.15;
  }

  .hero__subtitle {
    max-width: 640px;
    margin: 0.75rem auto 0;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.65;
  }

  .hero__updated {
    display: inline-block;
    margin-top: 0.85rem;
    font-size: 0.73rem;
    color: var(--color-success);
    font-weight: 600;
    background: var(--color-success-light);
    padding: 0.3rem 0.75rem;
    border-radius: var(--radius-full);
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.75rem;
    gap: 0.5rem;
  }

  .section-header h2 {
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .section-header a {
    font-size: 0.8rem;
    font-weight: 600;
    white-space: nowrap;
  }

  .district-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .district-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.75rem;
    background: var(--color-surface);
    border: 1.5px solid var(--color-border-light);
    border-radius: var(--radius);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-text);
    transition: all var(--transition);
  }

  .district-chip__count {
    font-weight: 800;
    color: var(--color-primary);
    font-size: 0.8rem;
  }

  .district-chip--accent .district-chip__count {
    color: var(--color-accent);
  }

  .recent-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  .recent-card__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.4rem;
  }

  .recent-card__number {
    font-weight: 700;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--color-primary);
  }

  .recent-card__date {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .recent-card__object {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .recent-card__footer {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.6rem;
    flex-wrap: wrap;
  }

  .recent-card__meta {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  .blog-home-card {
    display: block;
    color: var(--color-text);
    transition: all var(--transition);
    border-left: 3px solid transparent;
  }

  .blog-home-card__date {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .blog-home-card__title {
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.35;
    margin: 0.3rem 0 0.35rem;
    letter-spacing: -0.01em;
  }

  .blog-home-card__desc {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  @media (min-width: 640px) {
    .hero { padding: 2.5rem 0 1.5rem; }
    .hero h1 { font-size: 2.75rem; }
    .hero__subtitle { font-size: 1.05rem; line-height: 1.7; margin-top: 1rem; }
    .section-header h2 { font-size: 1.25rem; }
    .section-header { margin-bottom: 1rem; }
    .district-chip { padding: 0.5rem 1rem; font-size: 0.875rem; gap: 0.5rem; }
    .district-chip__count { font-size: 0.9rem; }
    .district-grid { gap: 0.5rem; }
    .recent-grid { grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem; }
    .recent-card__object { min-height: 3.5rem; }
    .blog-grid { grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem; }
    .blog-home-card__title { font-size: 1.05rem; }
  }

  @media (min-width: 640px) {
    .district-chip:hover {
      border-color: var(--color-primary);
      background: var(--color-primary-light);
      color: var(--color-primary);
      transform: translateY(-1px);
      box-shadow: var(--shadow-sm);
    }
    .district-chip--accent:hover {
      border-color: var(--color-accent);
      background: var(--color-accent-light);
      color: #92400e;
    }
    .blog-home-card:hover {
      border-left-color: var(--color-primary);
      box-shadow: var(--shadow-md);
      color: var(--color-text);
      transform: translateY(-2px);
    }
  }
</style>
