---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<Base
  title="Блог — Акт 16 Тракер"
  description="Статии за строителство, Акт 14, Акт 15, Акт 16, разрешения за строеж и пазара на недвижими имоти в София."
>
  <section class="blog-hero">
    <h1>Блог</h1>
    <p class="blog-hero__subtitle">
      Полезни статии за строителството, актовете и пазара на недвижими имоти в София.
    </p>
  </section>

  <section class="blog-list">
    {posts.map((post) => {
      const formattedDate = post.data.date.toLocaleDateString("bg-BG", {
        day: "numeric",
        month: "long",
        year: "numeric",
      });
      return (
        <a href={`/blog/${post.id}`} class="blog-card card">
          <div class="blog-card__meta">
            <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
          </div>
          <h2 class="blog-card__title">{post.data.title}</h2>
          <p class="blog-card__description">{post.data.description}</p>
          <div class="blog-card__tags">
            {post.data.tags.map((tag: string) => (
              <span class="blog-tag">{tag}</span>
            ))}
          </div>
        </a>
      );
    })}
  </section>
</Base>

<style>
  .blog-hero {
    text-align: center;
    padding: 1.5rem 0 1rem;
  }

  .blog-hero h1 {
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    background: linear-gradient(135deg, var(--color-primary), var(--color-coral));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .blog-hero__subtitle {
    max-width: 600px;
    margin: 0.5rem auto 0;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .blog-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1.5rem;
    max-width: 740px;
    margin-left: auto;
    margin-right: auto;
  }

  .blog-card {
    display: block;
    color: var(--color-text);
    transition: all var(--transition);
    border-left: 3px solid transparent;
  }

  .blog-card__meta {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    margin-bottom: 0.35rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .blog-card__title {
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 0.35rem;
    letter-spacing: -0.01em;
  }

  .blog-card__description {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .blog-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: 0.65rem;
  }

  .blog-tag {
    display: inline-block;
    padding: 0.2rem 0.55rem;
    background: var(--color-primary-light);
    color: var(--color-primary);
    border-radius: var(--radius-full);
    font-size: 0.68rem;
    font-weight: 600;
  }

  @media (min-width: 640px) {
    .blog-hero { padding: 2.5rem 0 1.5rem; }
    .blog-hero h1 { font-size: 2.5rem; }
    .blog-hero__subtitle { font-size: 1.05rem; line-height: 1.7; }
    .blog-list { gap: 1.25rem; margin-top: 2rem; }
    .blog-card__title { font-size: 1.3rem; }
    .blog-card__description { font-size: 0.9rem; }

    .blog-card:hover {
      border-left-color: var(--color-primary);
      box-shadow: var(--shadow-lg);
      color: var(--color-text);
      transform: translateY(-2px);
    }
  }
</style>
