---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const DEFAULT_DESCRIPTION = "Регистър на удостоверенията за въвеждане в експлоатация (Акт 16) и разрешенията за строеж в София — с данни от НАГ, обновявани ежедневно.";

const { title, description = DEFAULT_DESCRIPTION } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="bg">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl.href} />

    <meta name="theme-color" content="#7c3aed" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Акт 16" />
    <link rel="apple-touch-icon" href="/icons/icon-192.svg" />
    <link rel="manifest" href="/manifest.json" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:locale" content="bg_BG" />
    <meta property="og:site_name" content="Акт 16 Тракер" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <title>{title}</title>

    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-92FYWLG2LM"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-92FYWLG2LM');
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <nav class="nav">
          <a href="/" class="nav__logo">
            <span class="nav__logo-icon">16</span>
            Акт 16 Тракер
          </a>
          <ul class="nav__links">
            <li><a href="/">Начало</a></li>
            <li><a href="/register/act16">Акт 16</a></li>
            <li><a href="/register/permits">Разрешения</a></li>
            <li><a href="/stats">Статистика</a></li>
            <li><a href="/blog">Блог</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <main class="main">
      <div class="container">
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="footer__inner">
          <p>
            Данните са от публичния регистър на
            <a href="https://nag.sofia.bg" target="_blank" rel="noopener">НАГ — Столична община</a>.
          </p>
          <p class="footer__auto">Обновява се автоматично всеки ден.</p>
        </div>
      </div>
    </footer>

    <script is:inline>
      if ("serviceWorker" in navigator) {
        navigator.serviceWorker.register("/sw.js");
      }
    </script>
  </body>
</html>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border-light);
    padding: 0.65rem 0;
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(12px);
    background: rgba(255, 255, 255, 0.92);
  }

  .nav {
    display: flex;
    align-items: center;
    flex-direction: column;
    gap: 0.5rem;
  }

  .nav__logo {
    font-weight: 800;
    font-size: 1.05rem;
    color: var(--color-text);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    letter-spacing: -0.02em;
  }

  .nav__logo:hover {
    color: var(--color-primary);
  }

  .nav__logo-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: linear-gradient(135deg, var(--color-primary), var(--color-coral));
    color: white;
    font-size: 0.7rem;
    font-weight: 800;
    border-radius: 7px;
    letter-spacing: 0;
    flex-shrink: 0;
  }

  .nav__links {
    list-style: none;
    display: flex;
    gap: 0.1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .nav__links a {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-text-muted);
    padding: 0.35rem 0.55rem;
    border-radius: var(--radius);
    transition: all var(--transition);
  }

  .nav__links a:hover {
    color: var(--color-primary);
    background: var(--color-primary-light);
  }

  .main {
    flex: 1;
    padding: 1.25rem 0 2rem;
    padding-bottom: calc(2rem + var(--safe-bottom));
  }

  .site-footer {
    border-top: 1px solid var(--color-border-light);
    padding: 1.5rem 0;
    padding-bottom: calc(1.5rem + var(--safe-bottom));
    text-align: center;
  }

  .footer__inner {
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }

  .footer__auto {
    margin-top: 0.2rem;
    font-size: 0.7rem;
    opacity: 0.7;
  }

  @media (min-width: 640px) {
    .site-header { padding: 0.85rem 0; }

    .nav {
      flex-direction: row;
      justify-content: space-between;
    }

    .nav__logo { font-size: 1.15rem; gap: 0.6rem; }
    .nav__logo-icon { width: 30px; height: 30px; font-size: 0.75rem; border-radius: 8px; }

    .nav__links { gap: 0.35rem; }
    .nav__links a { font-size: 0.875rem; padding: 0.4rem 0.75rem; }

    .main { padding: 2rem 0 3rem; }
    .site-footer { padding: 2rem 0; }
    .footer__inner { font-size: 0.8rem; }
  }
</style>
